# ─── SECURITY: Test credential data files ────────────────────────────────────
# Ignore all JSON files in the data directory (sensitive data)
Test_cases/data/**/*.json

# Explicitly allow CSV files (non-sensitive test data)
!Test_cases/data/**/*.csv

